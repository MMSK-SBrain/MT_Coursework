# Anthropic API Key (required for AI question generation)
# Get your API key from: https://console.anthropic.com/settings/keys
# This key is used to generate contextual self-study questions via Claude API
# The questions are saved to staging files for mandatory review before inclusion
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Optional: Override default config path
HANDOUT_CONFIG_PATH=./handout_config.yaml

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
