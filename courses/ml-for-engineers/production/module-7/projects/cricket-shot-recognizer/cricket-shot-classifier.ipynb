{"cells":[{"cell_type":"markdown","metadata":{},"source":["# Cricket Shot Recognition - Complete Training Pipeline\n\n**Capstone Project: Module 7 - Computer Vision**\n\nBuild an end-to-end cricket shot classification system that:\n- Classifies 6 different cricket shots\n- Uses transfer learning (ResNet50)\n- Achieves >80% accuracy\n- Deploys as web application\n\n**Time Estimate:** 180-240 minutes"]},{"cell_type":"markdown","metadata":{},"source":["## Part 1: Setup and Data Loading"]},{"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["import numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\nimport seaborn as sns\nimport tensorflow as tf\nfrom tensorflow.keras.models import load_model\nfrom sklearn.metrics import classification_report, confusion_matrix\nimport os\nimport sys\n\n# Import custom modules\nfrom model_architecture import create_cricket_shot_model, compile_model, unfreeze_model, get_callbacks\nfrom data_augmentation import create_data_generators, visualize_augmentation, check_class_balance\n\nnp.random.seed(42)\ntf.random.set_seed(42)\n\nprint(f'TensorFlow version: {tf.__version__}')\nprint(f'GPU available: {tf.config.list_physical_devices(\"GPU\")}')"]}], {"cell_type":"markdown","metadata":{},"source":["## Part 2: Exploratory Data Analysis"]},{"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["# Create data generators\ntrain_gen, val_gen = create_data_generators(\n    train_dir='data/train',\n    val_dir='data/test',\n    batch_size=32,\n    img_size=(224, 224)\n)\n\n# Check class distribution\nprint('\\nTraining Data Distribution:')\ncheck_class_balance(train_gen)\n\nprint('\\nValidation Data Distribution:')\ncheck_class_balance(val_gen)\n\n# Visualize augmentation\nprint('\\nData Augmentation Examples:')\nvisualize_augmentation(train_gen, num_samples=9)"]},{"cell_type":"markdown","metadata":{},"source":["## Part 3: Model Architecture"]},{"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["# Create model\nmodel, base_model = create_cricket_shot_model(num_classes=6)\nmodel = compile_model(model, learning_rate=0.001)\n\n# Print model info\nfrom model_architecture import print_model_info\nprint_model_info(model)"]},{"cell_type":"markdown","metadata":{},"source":["## Part 4: Phase 1 - Feature Extraction Training"]},{"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["print('='*60)\nprint('PHASE 1: FEATURE EXTRACTION (Frozen Base Model)')\nprint('='*60)\n\n# Train with frozen base\nhistory_phase1 = model.fit(\n    train_gen,\n    epochs=20,\n    validation_data=val_gen,\n    callbacks=get_callbacks('models/cricket_model_phase1.h5')\n)\n\n# Save history\nimport pickle\nwith open('training_history_phase1.pkl', 'wb') as f:\n    pickle.dump(history_phase1.history, f)\n\nphase1_acc = history_phase1.history['val_accuracy'][-1]\nprint(f'\\nPhase 1 Best Validation Accuracy: {phase1_acc:.4f}')"]},{"cell_type":"markdown","metadata":{},"source":["## Part 5: Phase 2 - Fine-tuning"]},{"cell_type":"code","execution_count":null,"metadata":{},"outputs":[],"source":["print('='*60)\nprint('PHASE 2: FINE-TUNING (Unfreezing Top Layers)')\nprint('='*60)\n\n# Unfreeze top layers\nbase_model = unfreeze_model(base_model, num_layers_to_unfreeze=30)\n\n# Recompile with smaller learning rate\nmodel = compile_model(model, learning_rate=0.00001)\n\n# Continue training\nhistory_phase2 = model.fit(\n    train_gen,\n    epochs=15,\n    validation_data=val_gen,\n    callbacks=get_callbacks('models/cricket_shot_model.h5')\n)\n\n# Save history\nwith open('training_history_phase2.pkl', 'wb') as f:\n    pickle.dump(history_phase2.history, f)\n\nphase2_acc = history_phase2.history['val_accuracy'][-1]\nprint(f'\\nPhase 2 Best Validation Accuracy: {phase2_acc:.4f}')\nprint(f'Improvement: {(phase2_acc - phase1_acc)*100:.2f}%')"]}... [notebook continues with evaluation, visualization, and deployment sections]]
