    llm=llm,\
    chain_type="stuff",  # Simplest method: stuff all context into prompt\
    retriever=vectorstore.as_retriever(search_kwargs=\{"k": 3\})\
)\
\
# Test it!\
response = qa_chain.run("What is the compression ratio of the TSI engine?")\
print(response)\
