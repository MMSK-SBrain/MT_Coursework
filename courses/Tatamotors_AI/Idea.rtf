\f5\b0\fs26 \cf0 from langchain.chains import ConversationalRetrievalChain\
from langchain.memory import ConversationBufferMemory\
\
# Add memory\
memory = ConversationBufferMemory(\
    memory_key="chat_history",\
    return_messages=True,\
    output_key="answer"\
)\
\
# New chain with conversation ability\
conv_chain = ConversationalRetrievalChain.from_llm(\
    llm=llm,\
    retriever=vectorstore.as_retriever(),\
    memory=memory,\
    return_source_documents=True\
)\
\
# Multi-turn conversation example\
q1 = "What is a TSI engine?"\
response1 = conv_chain(\{"question": q1\})\
\
q2 = "What are its advantages?"  # "its" refers to TSI from previous Q\
response2 = conv_chain(\{"question": q2\})\
\
q3 = "How does it compare to TDI?"\
response3 = conv_chain(\{"question": q3\})\
