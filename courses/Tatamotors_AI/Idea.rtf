\f1\b \cf0 Part 3: Embeddings & Vector Store (40 min)\
\pard\pardeftab720\partightenfactor0

\f5\b0\fs26 \cf0 from langchain.embeddings import HuggingFaceEmbeddings\
from langchain.vectorstores import Chroma\
\
# Use FREE embedding model (no API cost!)\
embeddings = HuggingFaceEmbeddings(\
    model_name="sentence-transformers/all-MiniLM-L6-v2"\
    # This runs locally, no API calls!\
)\
\
# Create vector database\
vectorstore = Chroma.from_documents(\
    documents=chunks,\
    embedding=embeddings,\
    persist_directory="./chroma_db"  # Save to disk\
)\
\
# Test similarity search\
query = "How does the turbocharger work?"\
similar_docs = vectorstore.similarity_search(query, k=3)\
\
for i, doc in enumerate(similar_docs):\
    print(f"\\n--- Result \{i+1\} ---")\
    print(doc.page_content[:200])  # First 200 chars\
\pard\pardeftab720\sa240\partightenfactor0

