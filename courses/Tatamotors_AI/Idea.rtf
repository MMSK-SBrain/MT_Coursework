\f5\b0\fs26 \cf0 # Load multiple document types\
from langchain.document_loaders import (\
    PyPDFLoader,\
    CSVLoader,\
    UnstructuredHTMLLoader\
)\
\
# Load all documents\
loaders = [\
    PyPDFLoader("ssp_913_tsi.pdf"),\
    PyPDFLoader("ssp_676_dsg.pdf"),\
    CSVLoader("dtc_codes.csv"),\
    UnstructuredHTMLLoader("https://example.com/auto-basics")\
]\
\
all_docs = []\
for loader in loaders:\
    all_docs.extend(loader.load())\
\
# Add metadata for source tracking\
for i, doc in enumerate(all_docs):\
    doc.metadata['source_id'] = i\
    doc.metadata['source_type'] = type(loader).__name__\
\
# Create unified vector store\
vectorstore = Chroma.from_documents(\
    documents=all_docs,\
    embedding=embeddings\
)\
\pard\pardeftab720\sa280\partightenfactor0

