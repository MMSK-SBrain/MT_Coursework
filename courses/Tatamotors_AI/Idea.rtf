\f5\fs26 \cf0 # Step-by-step with explanations\
from langchain.document_loaders import PyPDFLoader\
from langchain.text_splitter import RecursiveCharacterTextSplitter\
\
# 1. Load the PDF\
loader = PyPDFLoader("vag_ssp_913_tsi_engine.pdf")\
documents = loader.load()\
\
# 2. Split into chunks\
# Why chunk? LLMs have context limits, need manageable pieces\
text_splitter = RecursiveCharacterTextSplitter(\
    chunk_size=1000,  # ~250 words\
    chunk_overlap=200,  # Overlap prevents splitting mid-sentence\
    separators=["\\n\\n", "\\n", ". ", " ", ""]\
)\
chunks = text_splitter.split_documents(documents)\
\
print(f"Split \{len(documents)\} pages into \{len(chunks)\} chunks")\
\pard\pardeftab720\sa240\partightenfactor0

